---
import { siteConfig, nav } from '@/lib/site-config';
---

<header class="border-b" style="border-color: var(--color-border);">
  <div class="container flex items-center justify-between py-4">
    <a href="/" class="flex flex-col no-underline" style="text-decoration: none;">
      <span class="text-2xl font-bold" style="font-family: var(--font-display); color: var(--color-text);">
        {siteConfig.name}
      </span>
      <span class="text-sm" style="color: var(--color-text-muted); margin-top: -2px;">
        {siteConfig.tagline}
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {nav.map(item => (
        <a
          href={item.href}
          class="text-sm font-semibold no-underline"
          style="color: var(--color-text-muted); text-decoration: none;"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav toggle -->
    <details class="md:hidden relative" id="mobile-nav">
      <summary class="list-none cursor-pointer p-2" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <nav
        class="absolute right-0 top-full mt-2 py-2 min-w-48 z-50"
        style="background: white; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); box-shadow: 0 8px 24px rgba(0,0,0,0.1);"
        aria-label="Mobile navigation"
      >
        {nav.map(item => (
          <a
            href={item.href}
            class="block px-4 py-2.5 text-sm font-semibold no-underline"
            style="color: var(--color-text); text-decoration: none;"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  details summary::-webkit-details-marker { display: none; }
  details[open] summary svg line:nth-child(1) { transform: rotate(45deg) translate(5px, -3px); }
  details[open] summary svg line:nth-child(2) { opacity: 0; }
  details[open] summary svg line:nth-child(3) { transform: rotate(-45deg) translate(5px, 3px); }
  nav a:hover { color: var(--color-accent) !important; }
</style>
