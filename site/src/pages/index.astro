---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConditionGrid from '@/components/ConditionGrid.astro';
import EmailCapture from '@/components/EmailCapture.astro';
import { siteConfig } from '@/lib/site-config';
import { buildWebSiteSchema } from '@/lib/schema';

import conditionsData from '@/data/conditions.json';
import trialsData from '@/data/trials.json';

const recruitingCount = trialsData.filter(t => t.status === 'RECRUITING').length;
const totalTrials = trialsData.length;
const conditionCount = conditionsData.length;
const today = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

const top100 = conditionsData.slice(0, 100);
---

<BaseLayout
  title="Find Clinical Trials You Actually Understand"
  description="Find clinical trials explained in plain English. We translate complex eligibility criteria so you can quickly see if a trial might be right for you or someone you love."
  schema={buildWebSiteSchema()}
>
  <!-- Hero -->
  <section class="section bg-hero" aria-labelledby="hero-heading">
    <div class="container-narrow text-center">
      <h1 id="hero-heading" class="mb-4 fade-up">
        Find Clinical Trials You Actually Understand
      </h1>
      <p class="text-lg mb-8 fade-up" style="color: var(--color-text-muted); max-width: 600px; margin-inline: auto; animation-delay: 0.1s;">
        We translate complex eligibility criteria into plain English, so you
        can quickly see if a trial might be right for you or someone you love.
      </p>

      <form role="search" class="mb-6 fade-up" style="animation-delay: 0.2s;" id="search-form">
        <label for="condition-search" class="sr-only">Search by condition or disease</label>
        <div class="flex flex-col sm:flex-row gap-3 max-w-xl mx-auto">
          <input
            id="condition-search"
            type="search"
            name="q"
            placeholder="e.g. breast cancer, type 2 diabetes, Crohn's disease"
            list="condition-suggestions"
            class="search-input flex-1 px-5 py-3.5 text-base"
          />
          <datalist id="condition-suggestions">
            {top100.map(c => (
              <option value={c.name} />
            ))}
          </datalist>
          <button type="submit" class="btn-primary">Find Trials</button>
        </div>
      </form>

      <div class="fade-up flex justify-center" style="animation-delay: 0.3s;">
        <div class="stats-bar">
          <span>{recruitingCount.toLocaleString()} recruiting trials</span>
          <span class="stats-dot" aria-hidden="true"></span>
          <span>{conditionCount} conditions</span>
          <span class="stats-dot" aria-hidden="true"></span>
          <span>Updated {today}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by Condition -->
  <section class="section" aria-labelledby="conditions-heading" id="conditions">
    <div class="container">
      <h2 id="conditions-heading" class="text-center mb-2">Browse by Condition</h2>
      <p class="text-center mb-8" style="color: var(--color-text-muted);">
        Select a condition to see all currently recruiting trials, explained in plain language.
      </p>
      <ConditionGrid conditions={conditionsData} limit={48} />
    </div>
  </section>

  <hr class="section-divider" />

  <!-- How Clinical Trials Work -->
  <section class="section bg-warm-section relative noise-overlay" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="text-center mb-8">How Clinical Trials Work</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <article class="info-card">
          <div class="info-card-icon" style="background: var(--color-hope-light);" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-hope)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12h6M12 9v6"/>
              <circle cx="12" cy="12" r="10"/>
            </svg>
          </div>
          <h3 class="mb-2">What Is a Clinical Trial?</h3>
          <p class="text-sm mb-4" style="color: var(--color-text-muted);">
            Research studies that test new treatments, medications, or medical devices in volunteers.
          </p>
          <a href="/guides/what-is-a-clinical-trial/" class="btn-secondary text-sm">
            Learn more &rarr;
          </a>
        </article>

        <article class="info-card">
          <div class="info-card-icon" style="background: var(--color-pending-light);" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-pending)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
          </div>
          <h3 class="mb-2">What Are Trial Phases?</h3>
          <p class="text-sm mb-4" style="color: var(--color-text-muted);">
            Trials go through 4 phases, from initial safety testing to large-scale effectiveness studies.
          </p>
          <a href="/guides/what-are-trial-phases/" class="btn-secondary text-sm">
            Learn more &rarr;
          </a>
        </article>

        <article class="info-card">
          <div class="info-card-icon" style="background: var(--color-accent-light);" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3 class="mb-2">Is It Safe to Participate?</h3>
          <p class="text-sm mb-4" style="color: var(--color-text-muted);">
            Every trial on ClinicalTrials.gov is reviewed by an independent ethics committee.
          </p>
          <a href="/guides/how-to-join-a-clinical-trial/" class="btn-secondary text-sm">
            Learn more &rarr;
          </a>
        </article>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Email Capture -->
  <div class="container section-sm">
    <EmailCapture
      heading="Be Notified When New Trials Open"
      description="Tell us your condition. We'll email you the moment a new recruiting trial opens that matches — with the eligibility explained in plain English."
      subject="TrialFinder — Trial Alert Signup"
      buttonText="Send Me Trial Alerts →"
      showConditionField={true}
      showRoleField={true}
    />
  </div>
</BaseLayout>

<script>
  // Search form redirect
  const form = document.getElementById('search-form') as HTMLFormElement;
  const input = document.getElementById('condition-search') as HTMLInputElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const query = input?.value.trim();
    if (!query) return;

    const slug = query
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/[\s_]+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');

    window.location.href = `/condition/${slug}/`;
  });

  // Scroll-triggered fade-in
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.scroll-fade').forEach(el => observer.observe(el));
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
