---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { siteConfig } from '@/lib/site-config';
import { buildFAQSchema, buildBreadcrumbSchema } from '@/lib/schema';

const title = "Clinical Trial FAQ — Common Questions Answered";
const description = "Frequently asked questions about clinical trials answered in plain English. Covers eligibility, safety, costs, placebos, rights, and what to expect during a trial.";
const url = `${siteConfig.url}/faq/`;

const breadcrumbItems = [
  { label: 'FAQ' },
];

const faqCategories = [
  {
    name: 'Getting Started',
    faqs: [
      {
        question: 'What is a clinical trial?',
        answer: 'A clinical trial is a carefully designed research study that tests a medical treatment, device, or approach in people. Trials follow strict rules reviewed by independent ethics boards to protect participants. Every approved medication you take today was once tested in a clinical trial.',
      },
      {
        question: 'Why should I consider joining a clinical trial?',
        answer: 'Clinical trials can give you access to new treatments before they are widely available. You receive close monitoring from a research team, and you contribute to medical knowledge that helps future patients. Many participants report feeling empowered by taking an active role in their care.',
      },
      {
        question: 'How do I find a clinical trial for my condition?',
        answer: 'You can search by condition here on ClinicalTrialHub, where eligibility criteria are translated into plain English. You can also search ClinicalTrials.gov, ask your doctor, or contact a patient advocacy group for your condition. Our guide on <a href="/guides/how-to-join-a-clinical-trial/">how to join a clinical trial</a> walks through the full process.',
      },
      {
        question: 'Do I need my doctor to refer me to a trial?',
        answer: 'Not always. Many trials allow you to contact the research team directly. However, discussing a trial with your doctor is a good idea because they can help you evaluate whether it is a good fit for your situation and coordinate your care if you decide to enroll.',
      },
      {
        question: 'What are the different phases of clinical trials?',
        answer: 'There are four main phases. Phase 1 tests safety and dosing in a small group. Phase 2 evaluates effectiveness in a larger group. Phase 3 compares the treatment to existing options in hundreds or thousands of people. Phase 4 monitors the treatment after it has been approved. See our <a href="/guides/what-are-trial-phases/">trial phases guide</a> for details.',
      },
    ],
  },
  {
    name: 'Eligibility',
    faqs: [
      {
        question: 'Who can participate in a clinical trial?',
        answer: 'Eligibility varies by trial. Each study has specific criteria based on factors like age, gender, type and stage of disease, treatment history, and overall health. Some trials are broad, while others are highly specific. Being ineligible for one trial does not mean you are ineligible for others.',
      },
      {
        question: 'What are inclusion and exclusion criteria?',
        answer: 'Inclusion criteria are the characteristics you must have to join a trial — for example, a specific diagnosis or age range. Exclusion criteria are factors that prevent you from participating, such as certain medications or coexisting conditions. These criteria exist to protect participants and ensure reliable results. Our <a href="/guides/how-to-read-eligibility-criteria/">eligibility guide</a> explains how to read them.',
      },
      {
        question: 'Can I join a trial if I have other health conditions?',
        answer: 'It depends on the specific trial. Some studies exclude participants with certain conditions because those conditions could interfere with the results or increase risk. Others are designed specifically for people with multiple health issues. Check the eligibility criteria for each trial you are interested in.',
      },
      {
        question: 'Are clinical trials only for adults?',
        answer: 'No. Many trials specifically recruit children and adolescents. Pediatric trials have additional safety protections and require both parental consent and the child\'s assent when they are old enough to understand. Learn more in our <a href="/guides/clinical-trials-for-children/">guide to pediatric trials</a>.',
      },
    ],
  },
  {
    name: 'During the Trial',
    faqs: [
      {
        question: 'What happens after I enroll in a trial?',
        answer: 'After enrollment, you will go through screening tests to confirm eligibility. Then you will be assigned to a treatment group, either randomly or by the research team. You will receive the study treatment and attend regular appointments for monitoring, tests, and check-ins with the research team.',
      },
      {
        question: 'Will I definitely receive the new treatment?',
        answer: 'Not necessarily. In randomized trials, you may be assigned to a control group that receives the current standard treatment or, in some cases, a placebo. The consent document will explain the odds of being in each group. In single-arm trials, everyone receives the new treatment.',
      },
      {
        question: 'What is a placebo and will I get one?',
        answer: 'A placebo is an inactive substance that looks like the real treatment. Placebos are only used when ethically appropriate — if an effective treatment already exists, the control group receives that treatment, not a placebo. You will always be told before enrolling whether a placebo is involved.',
      },
      {
        question: 'How often will I need to visit the clinic?',
        answer: 'Visit frequency varies widely. Some trials require weekly visits, especially at the beginning. Others may only need monthly check-ins. Increasingly, some trials include remote monitoring and telemedicine visits. The schedule will be explained during informed consent before you commit.',
      },
      {
        question: 'Can I continue taking my regular medications?',
        answer: 'This depends on the trial. Some studies require you to stop certain medications that could interfere with the treatment being tested. Others allow all current medications. Never change your medication regimen without discussing it with both the research team and your personal doctor.',
      },
    ],
  },
  {
    name: 'Safety & Rights',
    faqs: [
      {
        question: 'How is my safety protected during a trial?',
        answer: 'Multiple layers of oversight protect you. An Institutional Review Board (IRB) approves the study before it begins. A Data Safety Monitoring Board reviews safety data throughout the trial. The FDA enforces strict regulations on trial conduct. You can leave at any time if you have concerns.',
      },
      {
        question: 'Can I leave a clinical trial at any time?',
        answer: 'Yes, absolutely. You can withdraw from a trial at any time, for any reason, without penalty. This right is guaranteed by federal regulations and stated in every consent document. Leaving a trial will not affect your access to regular medical care.',
      },
      {
        question: 'What is informed consent?',
        answer: 'Informed consent is an ongoing process where the research team explains the trial — its purpose, procedures, risks, benefits, and alternatives — and you voluntarily agree to participate. It is not just a form to sign; it is a conversation. You can ask questions at any point and take the document home to review. See our <a href="/guides/understanding-informed-consent/">informed consent guide</a> for details.',
      },
      {
        question: 'What happens if I experience side effects?',
        answer: 'Report all side effects to the research team immediately, no matter how minor they seem. The team will assess the severity, adjust your treatment if needed, and provide appropriate medical care. Serious adverse events trigger additional safety reviews that may affect the entire trial.',
      },
      {
        question: 'Is my personal information kept private?',
        answer: 'Yes. Your medical information is protected by privacy regulations including HIPAA. Trial data is coded so that your identity is not linked to your results in publications or reports. Only authorized members of the research team and regulatory agencies can access your identifiable information.',
      },
    ],
  },
  {
    name: 'Costs & Logistics',
    faqs: [
      {
        question: 'Does it cost money to participate in a clinical trial?',
        answer: 'The study treatment and trial-related tests are almost always provided free of charge by the trial sponsor. However, standard-of-care costs are typically billed to your insurance as they normally would be. Travel, lodging, and time off work may or may not be reimbursed depending on the study.',
      },
      {
        question: 'Will my insurance cover clinical trial costs?',
        answer: 'Most insurance plans, including Medicare, are required to cover routine care costs during a clinical trial. The experimental treatment itself is covered by the sponsor. Contact your insurance provider before enrolling to understand what will be covered and what your out-of-pocket costs might be.',
      },
      {
        question: 'Do trials only take place at major hospitals?',
        answer: 'No. While many trials are based at academic medical centers, research also happens at community hospitals, private clinics, and doctor\'s offices. Some trials now include remote participation with medications shipped to your home and virtual check-ins. Search by location to find trials near you.',
      },
      {
        question: 'How long does a clinical trial last?',
        answer: 'Trial duration varies enormously. Some studies last a few weeks, while others continue for several years. Phase 1 trials tend to be shorter, while Phase 3 trials are often longer. The exact timeline will be outlined in the consent document before you decide to participate.',
      },
    ],
  },
  {
    name: 'After the Trial',
    faqs: [
      {
        question: 'What happens when the trial ends?',
        answer: 'When a trial ends, the research team will discuss your next steps. You will transition back to standard care with your regular doctor. In some cases, if the treatment was effective, you may be offered continued access through an extension study or expanded access program.',
      },
      {
        question: 'Will I find out the results of the trial?',
        answer: 'You have a right to request a summary of the trial results once they are available. Many trials also publish their findings in medical journals and on ClinicalTrials.gov. Results can take months or years to analyze and publish after the trial concludes.',
      },
      {
        question: 'Can I access the treatment after the trial ends?',
        answer: 'Sometimes. If the treatment is effective and the trial is complete, the sponsor may offer continued access through compassionate use or an open-label extension study while regulatory approval is pending. This is not guaranteed and depends on the sponsor and the regulatory situation.',
      },
    ],
  },
];

const allFaqs = faqCategories.flatMap(cat => cat.faqs);

const schema = [
  buildFAQSchema(allFaqs),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteConfig.url },
    { name: 'FAQ', url },
  ]),
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="container-narrow section-sm">
    <Breadcrumb items={breadcrumbItems} />

    <h1>{title}</h1>
    <p style="color: var(--color-text-muted); max-width: 42rem;">
      Quick answers to the most common questions about clinical trials. For deeper dives, follow the links to our <a href="/guides/">patient guides</a>.
    </p>

    <div class="faq-content">
      {faqCategories.map(category => (
        <section class="faq-category" aria-labelledby={`cat-${category.name.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}>
          <h2 id={`cat-${category.name.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} class="faq-category__title">{category.name}</h2>
          {category.faqs.map(faq => (
            <details class="faq-item">
              <summary class="faq-item__question">{faq.question}</summary>
              <div class="faq-item__answer" set:html={faq.answer} />
            </details>
          ))}
        </section>
      ))}
    </div>

    <div class="prose" style="margin-top: 3rem;">
      <h2>Still have questions?</h2>
      <p>
        Our <a href="/guides/">patient guides</a> cover each topic in depth, from <a href="/guides/what-is-a-clinical-trial/">what a clinical trial is</a> to <a href="/guides/understanding-informed-consent/">understanding informed consent</a>. You can also <a href="/">search for a trial</a> by condition and see eligibility criteria explained in plain English.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .faq-content {
    margin-top: 2rem;
  }

  .faq-category {
    margin-bottom: 2.5rem;
  }

  .faq-category__title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border, #e5e0d8);
    color: var(--color-heading, #1a1a1a);
  }

  .faq-item {
    border: 1px solid var(--color-border, #e5e0d8);
    border-radius: 0.5rem;
    margin-bottom: 0.5rem;
    background: var(--color-surface, #fff);
    overflow: hidden;
  }

  .faq-item[open] {
    border-color: var(--color-primary, #4a7c6f);
  }

  .faq-item__question {
    padding: 1rem 1.25rem;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.975rem;
    color: var(--color-heading, #1a1a1a);
    line-height: 1.4;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__question::before {
    content: '+';
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--color-bg-muted, #f5f0eb);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary, #4a7c6f);
    transition: transform 0.15s ease;
  }

  .faq-item[open] .faq-item__question::before {
    content: '\2212';
  }

  .faq-item__answer {
    padding: 0 1.25rem 1rem 3.5rem;
    font-size: 0.925rem;
    line-height: 1.6;
    color: var(--color-text, #333);
  }

  .faq-item__answer a {
    color: var(--color-primary, #4a7c6f);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .faq-item__answer a:hover {
    color: var(--color-primary-dark, #3a6359);
  }
</style>
