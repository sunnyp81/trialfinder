---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import TrialCard from '@/components/TrialCard.astro';
import { siteConfig } from '@/lib/site-config';
import { buildBreadcrumbSchema } from '@/lib/schema';

import drugsData from '@/data/drugs.json';
import trialsData from '@/data/trials.json';

export function getStaticPaths() {
  return drugsData.map(drug => {
    const drugLower = drug.name.toLowerCase();
    const matchingTrials = trialsData.filter(t =>
      t.interventions.some((i: any) => i.name.toLowerCase() === drugLower)
    );

    return {
      params: { slug: drug.slug },
      props: { drug, trials: matchingTrials },
    };
  });
}

const { drug, trials } = Astro.props;

const recruiting = trials.filter((t: any) => t.status === 'RECRUITING');
const enrolling = trials.filter((t: any) => t.status === 'NOT_YET_RECRUITING');
const totalActive = recruiting.length + enrolling.length;

// Deduplicate conditions from matching trials
const conditionSet = new Map<string, string>();
trials.forEach((t: any) => {
  t.conditions.forEach((c: string) => {
    const slug = c.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    if (!conditionSet.has(slug)) {
      conditionSet.set(slug, c);
    }
  });
});
const conditions = Array.from(conditionSet.entries()).map(([slug, name]) => ({ slug, name }));

const schemas = [
  buildBreadcrumbSchema([
    { name: 'Home', url: siteConfig.url },
    { name: 'Treatments', url: `${siteConfig.url}/drug/` },
    { name: drug.name, url: `${siteConfig.url}/drug/${drug.slug}/` },
  ]),
];

const drugSearchUrl = `https://clinicaltrials.gov/search?intr=${encodeURIComponent(drug.name)}&aggFilters=status:rec`;
---

<BaseLayout
  title={`${drug.name} Clinical Trials — Recruiting Now`}
  description={`${totalActive} clinical trials for ${drug.name} currently recruiting. See plain English eligibility criteria.`}
  schema={schemas}
>
  <div class="container section-sm">
    <Breadcrumb items={[
      { label: 'Treatments', href: '/drug/' },
      { label: drug.name },
    ]} />

    <article>
      <header class="mb-8">
        <h1 class="mb-3">{drug.name} — Clinical Trials Currently Recruiting</h1>
        <p style="color: var(--color-text-muted);">
          Treatment type: {drug.type} &middot; {totalActive} active trial{totalActive !== 1 ? 's' : ''}
        </p>
      </header>

      <section aria-labelledby="intro-heading" class="mb-8">
        <h2 id="intro-heading" class="sr-only">About these trials</h2>
        <div class="prose">
          <p>
            The following trials are currently recruiting participants for studies
            involving {drug.name}. Each listing shows the plain-English eligibility
            criteria so you can quickly see if you or a loved one might qualify.
          </p>
        </div>
      </section>

      {recruiting.length > 0 && (
        <section aria-labelledby="recruiting-heading" class="mb-10">
          <h2 id="recruiting-heading" class="mb-4">
            Recruiting Now ({recruiting.length})
          </h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {recruiting.map((trial: any) => (
              <TrialCard trial={trial} />
            ))}
          </div>
        </section>
      )}

      {enrolling.length > 0 && (
        <section aria-labelledby="upcoming-heading" class="mb-10">
          <h2 id="upcoming-heading" class="mb-4" style="color: var(--color-text-muted);">
            Opening Soon ({enrolling.length})
          </h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" style="opacity: 0.85;">
            {enrolling.map((trial: any) => (
              <TrialCard trial={trial} />
            ))}
          </div>
        </section>
      )}

      {totalActive === 0 && (
        <section class="mb-10 p-6" style="background: var(--color-bg-alt); border-radius: var(--radius-lg);">
          <p style="color: var(--color-text-muted);">
            There are currently no recruiting trials involving {drug.name} in our database.
            New trials are added regularly — check back soon or
            <a href={drugSearchUrl} rel="noopener noreferrer" target="_blank">search ClinicalTrials.gov directly</a>.
          </p>
        </section>
      )}

      {conditions.length > 0 && (
        <section aria-labelledby="conditions-heading" class="mb-10 p-6" style="background: var(--color-bg-alt); border-radius: var(--radius-lg);">
          <h2 id="conditions-heading" class="text-lg mb-3">Conditions Being Treated</h2>
          <ul class="space-y-2" style="list-style: none; padding: 0;">
            {conditions.map(c => (
              <li>
                <a href={`/condition/${c.slug}/`}>{c.name}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section aria-labelledby="questions-heading" class="mb-10 p-6" style="background: var(--color-bg-alt); border-radius: var(--radius-lg);">
        <h2 id="questions-heading" class="text-lg mb-3">What to Ask Your Doctor</h2>
        <ul class="space-y-2" style="padding-left: 1.25rem;">
          <li>Is {drug.name} appropriate for my specific diagnosis, stage, and overall health?</li>
          <li>What are the known side effects, and how do they compare to my current treatment?</li>
          <li>Would joining a clinical trial give me access to {drug.name} sooner than waiting for approval?</li>
          <li>Are there other treatments or combinations I should consider alongside or instead of {drug.name}?</li>
        </ul>
        <p class="text-sm mt-4">
          <a href="/guides/questions-to-ask-your-doctor/">See our full list of questions to ask your doctor about clinical trials &rarr;</a>
        </p>
      </section>

      <aside class="mb-10 p-5" style="background: var(--color-bg-warn, #fef9ef); border-radius: var(--radius-lg); border-left: 4px solid var(--color-accent);">
        <p class="text-sm" style="color: var(--color-text-muted); margin: 0;">
          <strong>Disclaimer:</strong> This page lists trials involving {drug.name} as registered
          on ClinicalTrials.gov. It does not constitute an endorsement of this treatment.
          Always consult your doctor before making treatment decisions.
        </p>
      </aside>

      <p class="text-sm" style="color: var(--color-text-light);">
        Source: <a href={drugSearchUrl} rel="noopener noreferrer" target="_blank">
          Search ClinicalTrials.gov for {drug.name} &rarr;
        </a>
      </p>
    </article>
  </div>
</BaseLayout>
